<Window x:Class="ZapretWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ObhodLauncher" Height="500" Width="720"
        Background="#1e1e1e" Foreground="White">

    <!-- Добавляем стили для красивых вкладок -->
    <Window.Resources>
        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" Padding="15,8" Margin="0,0,2,0" Background="#2d2d30" CornerRadius="5,5,0,0">
                            <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="5,2"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#3e3e42" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <TabControl Background="#1e1e1e" BorderThickness="0" Margin="10">

        <!-- ВКЛАДКА 1: ОБХОД DPI -->
        <TabItem Header="Обход DPI (Flowseal + Custom)">
            <Grid Margin="10,15,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                    <CheckBox x:Name="chkDiscord" Content="Discord" IsChecked="True" Foreground="White" Margin="0,0,15,0" FontSize="14" VerticalAlignment="Center"/>
                    <CheckBox x:Name="chkYouTube" Content="YouTube" IsChecked="True" Foreground="White" Margin="0,0,25,0" FontSize="14" VerticalAlignment="Center"/>

                    <TextBlock Text="Стратегия:" Foreground="White" FontSize="14" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox x:Name="cmbStrategy" Width="260" SelectedIndex="0" FontSize="13">
                        <ComboBoxItem Content="1. Flowseal (General)"/>
                        <ComboBoxItem Content="2. Flowseal (ALT 1)"/>
                        <ComboBoxItem Content="3. Flowseal (ALT 2)"/>
                        <ComboBoxItem Content="4. Flowseal (ALT 3)"/>
                        <ComboBoxItem Content="5. Flowseal (FAKE TLS AUTO ALT)"/>
                        <ComboBoxItem Content="6. SupaModd Custom (Макс. Пробив)"/>
                    </ComboBox> 
                </StackPanel>

                <!-- Окно логов консоли -->
                <TextBox x:Name="txtLogs" Grid.Row="1" Background="#252526" Foreground="#4AF626" 
                         IsReadOnly="True" TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto" 
                         FontFamily="Consolas" BorderThickness="0" Padding="10"/>

                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                    <Button Content="Тест в окне" Width="100" Height="35" Margin="0,0,10,0" Click="BtnStart_Click"/>
                    <Button Content="Стоп тест" Width="90" Height="35" Margin="0,0,30,0" Click="BtnStop_Click"/>

                    <Button Content="Запустить Службу" Background="#2e7d32" Foreground="White" Width="140" Height="35" Margin="0,0,10,0" Click="BtnInstallService_Click"/>
                    <Button Content="Удалить Службу" Background="#c62828" Foreground="White" Width="130" Height="35" Click="BtnRemoveService_Click"/>
                </StackPanel>
            </Grid>
        </TabItem>

        <!-- ВКЛАДКА 2: ДОП ФУНКЦИИ (Заготовка на будущее) -->
        <TabItem Header="Доп. Утилиты (Скоро)">
            <Grid Margin="15">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Здесь будут новые фишки!" FontSize="24" FontWeight="Bold" Foreground="#888" HorizontalAlignment="Center"/>
                    <TextBlock Text="Например: Пингователь, очистка кэша, скачивание списков." FontSize="16" Foreground="#666" Margin="0,10,0,0" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </TabItem>

    </TabControl>
</Window>