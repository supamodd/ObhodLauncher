<Window x:Class="ZapretWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ObhodLauncher" Height="450" Width="650"
        Background="#1e1e1e" Foreground="White">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Zapret: Управление обходом" FontSize="22" FontWeight="Bold" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,15">
            <CheckBox x:Name="chkDiscord" Content="Discord" IsChecked="True" Foreground="White" Margin="0,0,15,0" FontSize="14"/>
            <CheckBox x:Name="chkYouTube" Content="YouTube" IsChecked="True" Foreground="White" FontSize="14"/>
        </StackPanel>

        <!-- Окно логов консоли -->
        <TextBox x:Name="txtLogs" Grid.Row="2" Background="#252526" Foreground="#4AF626" 
                 IsReadOnly="True" TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto" 
                 FontFamily="Consolas" BorderThickness="0" Padding="10"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Старт (Консоль)" Width="120" Height="35" Margin="0,0,10,0" Click="BtnStart_Click"/>
            <Button Content="Стоп" Width="90" Height="35" Margin="0,0,10,0" Click="BtnStop_Click"/>
            <Button Content="Установить Службу" Width="140" Height="35" Click="BtnInstallService_Click"/>
        </StackPanel>
    </Grid>
</Window>