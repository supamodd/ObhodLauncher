<Window x:Class="ZapretWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SupaModd Launcher" Height="550" Width="800"
        Background="#18181b" Foreground="#e0e0e0"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Акцентный цвет (можешь поменять на любой, например #007acc) -->
        <SolidColorBrush x:Key="AccentColor" Color="#8b5cf6"/>
        <SolidColorBrush x:Key="AccentColorHover" Color="#7c3aed"/>
        <SolidColorBrush x:Key="BgColor" Color="#18181b"/>
        <SolidColorBrush x:Key="CardColor" Color="#27272a"/>

        <!-- Стиль для красивых закругленных кнопок -->
        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource CardColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3f3f46"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#52525b"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Акцентная кнопка -->
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource AccentColorHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#6d28d9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Кнопка Остановки (Красная) -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource ModernButton}">
            <Setter Property="Background" Value="#ef4444"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#dc2626"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Исправленный стиль переключателей (Toggle Switch) -->
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <StackPanel Orientation="Horizontal" Background="Transparent">
                            <Border x:Name="SwitchBg" Width="40" Height="22" CornerRadius="11" Background="#3f3f46" VerticalAlignment="Center">
                                <!-- Мы убрали TranslateTransform, меняем просто Margin для движения -->
                                <Ellipse x:Name="SwitchThumb" Width="16" Height="16" Fill="White" HorizontalAlignment="Left" Margin="3,0,0,0"/>
                            </Border>
                            <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchBg" Property="Background" Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="SwitchThumb" Property="Margin" Value="21,0,0,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Верхняя шапка с заголовком -->
        <Grid Height="60" VerticalAlignment="Top" Background="{StaticResource CardColor}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                <TextBlock Text="🚀" FontSize="24" Margin="0,0,10,0" VerticalAlignment="Center"/>
                <TextBlock Text="SupaModd Launcher" FontSize="22" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                <TextBlock Text="v1.0" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource AccentColor}" VerticalAlignment="Bottom" Margin="10,0,0,4"/>
            </StackPanel>
        </Grid>

        <!-- Основной контент со вкладками (отступ сверху 60) -->
        <TabControl Background="Transparent" BorderThickness="0" Margin="15,75,15,15">

            <!-- ВКЛАДКА 1: ОБХОД DPI -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="Обход DPI" FontSize="16" FontWeight="SemiBold" Padding="10,5"/>
                </TabItem.Header>
                <Grid Margin="5,15,5,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Панель управления -->
                    <Border Background="{StaticResource CardColor}" CornerRadius="10" Padding="20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Переключатели -->
                            <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,30,0">
                                <CheckBox x:Name="chkDiscord" Content="Разблокировать Discord" IsChecked="True" Style="{StaticResource ToggleSwitch}" Margin="0,0,0,15"/>
                                <CheckBox x:Name="chkYouTube" Content="Разблокировать YouTube" IsChecked="True" Style="{StaticResource ToggleSwitch}"/>
                            </StackPanel>

                            <!-- Выбор стратегии -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Метод обхода (Стратегия):" Foreground="#a1a1aa" FontSize="13" Margin="0,0,0,5"/>
                                <ComboBox x:Name="cmbStrategy" Height="35" FontSize="14" SelectedIndex="5" Padding="10,5">
                                    <ComboBoxItem Content="1. Flowseal (General)"/>
                                    <ComboBoxItem Content="2. Flowseal (ALT 1 - Fake)"/>
                                    <ComboBoxItem Content="3. Flowseal (ALT 2 - Disorder)"/>
                                    <ComboBoxItem Content="4. Flowseal (ALT 3 - Hostfakesplit)"/>
                                    <ComboBoxItem Content="5. Flowseal (FAKE TLS AUTO ALT)"/>
                                    <ComboBoxItem Content="6. SupaModd Custom (Макс. Пробив)"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Заголовок логов -->
                    <TextBlock Grid.Row="1" Text="Логи системы (Консоль):" Foreground="#a1a1aa" FontSize="13" Margin="5,15,0,5"/>

                    <!-- Окно логов консоли -->
                    <Border Grid.Row="2" Background="#09090b" CornerRadius="8" BorderThickness="1" BorderBrush="#3f3f46">
                        <TextBox x:Name="txtLogs" Background="Transparent" Foreground="#4ade80" 
                                 IsReadOnly="True" TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto" 
                                 FontFamily="Consolas" BorderThickness="0" Padding="15" FontSize="13"/>
                    </Border>

                    <!-- Нижние кнопки -->
                    <Grid Grid.Row="3" Margin="0,15,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <Button Content="▶ Тест в окне" Width="130" Style="{StaticResource AccentButton}" Margin="0,0,10,0" Click="BtnStart_Click"/>
                            <Button Content="⏹ Остановить тест" Width="130" Style="{StaticResource ModernButton}" Click="BtnStop_Click"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="🛡 Установить как Службу" Width="190" Style="{StaticResource ModernButton}" Margin="0,0,10,0" Click="BtnInstallService_Click"/>
                            <Button Content="Удалить Службу" Width="140" Style="{StaticResource DangerButton}" Click="BtnRemoveService_Click"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ВКЛАДКА 2: ДОП ФУНКЦИИ -->
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="Инструменты" FontSize="16" FontWeight="SemiBold" Padding="10,5"/>
                </TabItem.Header>
                <Grid Margin="5,15,5,0">
                    <!-- Заготовка карточек для будущих фишек -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,50,0,0">

                        <!-- Карточка 1 -->
                        <Border Background="{StaticResource CardColor}" CornerRadius="10" Width="220" Height="200" Margin="0,0,20,0" Padding="20">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="🌐" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <TextBlock Text="Тест соединения" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <TextBlock Text="Быстрая проверка доступности серверов Discord." TextWrapping="Wrap" TextAlignment="Center" Foreground="#a1a1aa" Margin="0,0,0,15"/>
                                <Button Content="Скоро" Style="{StaticResource ModernButton}" IsEnabled="False"/>
                            </StackPanel>
                        </Border>

                        <!-- Карточка 2 -->
                        <Border Background="{StaticResource CardColor}" CornerRadius="10" Width="220" Height="200" Margin="0,0,20,0" Padding="20">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="🔄" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <TextBlock Text="Обновление списков" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <TextBlock Text="Скачивание актуальных доменов с GitHub." TextWrapping="Wrap" TextAlignment="Center" Foreground="#a1a1aa" Margin="0,0,0,15"/>
                                <Button Content="Скоро" Style="{StaticResource ModernButton}" IsEnabled="False"/>
                            </StackPanel>
                        </Border>

                        <!-- Карточка 3 -->
                        <Border Background="{StaticResource CardColor}" CornerRadius="10" Width="220" Height="200" Padding="20">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="🧹" FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                <TextBlock Text="Сброс сети" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
                                <TextBlock Text="Очистка кэша DNS (flushdns) для решения проблем." TextWrapping="Wrap" TextAlignment="Center" Foreground="#a1a1aa" Margin="0,0,0,15"/>
                                <Button Content="Скоро" Style="{StaticResource ModernButton}" IsEnabled="False"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>