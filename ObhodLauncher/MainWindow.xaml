<Window x:Class="ZapretWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="SupaModd Launcher" Height="580" Width="840"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        WindowStyle="SingleBorderWindow"
        AllowsTransparency="False"
        Background="#0f0f13">

    <!-- Глобальные ресурсы для Glass-эффекта и кнопок -->
    <Window.Resources>
        <!-- Полупрозрачные цвета для эффекта стекла -->
        <SolidColorBrush x:Key="GlassBg" Color="#9918181b"/>
        <!-- 60% прозрачность -->
        <SolidColorBrush x:Key="GlassBorder" Color="#33ffffff"/>
        <!-- Тонкая светлая рамка -->

        <!-- Акцентные цвета -->
        <SolidColorBrush x:Key="AccentColor" Color="#8b5cf6"/>
        <SolidColorBrush x:Key="AccentColorHover" Color="#a78bfa"/>

        <!-- Базовый шаблон для кнопок (Стекло) -->
        <ControlTemplate x:Key="GlassButtonTemplate" TargetType="Button">
            <Border x:Name="border" Background="#26ffffff" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" CornerRadius="8" Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="border" Property="Background" Value="#33ffffff"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="border" Property="Background" Value="#1affffff"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="GlassButton" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template" Value="{StaticResource GlassButtonTemplate}"/>
        </Style>

        <!-- Акцентная кнопка -->
        <ControlTemplate x:Key="AccentButtonTemplate" TargetType="Button">
            <Border x:Name="border" Background="{StaticResource AccentColor}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="border" Property="Background" Value="{StaticResource AccentColorHover}"/>
                    <Setter TargetName="border" Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#8b5cf6" BlurRadius="15" ShadowDepth="0" Opacity="0.5"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="border" Property="Background" Value="#7c3aed"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource GlassButton}">
            <Setter Property="Template" Value="{StaticResource AccentButtonTemplate}"/>
        </Style>

        <!-- Кнопка Остановки (Красная) -->
        <ControlTemplate x:Key="DangerButtonTemplate" TargetType="Button">
            <Border x:Name="border" Background="#ef4444" CornerRadius="8" Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="border" Property="Background" Value="#f87171"/>
                    <Setter TargetName="border" Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#ef4444" BlurRadius="15" ShadowDepth="0" Opacity="0.5"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter TargetName="border" Property="Background" Value="#dc2626"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource GlassButton}">
            <Setter Property="Template" Value="{StaticResource DangerButtonTemplate}"/>
        </Style>

        <!-- Анимированный Toggle Switch -->
        <ControlTemplate x:Key="ToggleSwitchTemplate" TargetType="CheckBox">
            <StackPanel Orientation="Horizontal" Background="Transparent">
                <Border x:Name="SwitchBg" Width="44" Height="24" CornerRadius="12" Background="#40ffffff" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" VerticalAlignment="Center">
                    <Ellipse x:Name="SwitchThumb" Width="16" Height="16" Fill="White" HorizontalAlignment="Left" Margin="3,0,0,0">
                        <Ellipse.RenderTransform>
                            <TranslateTransform x:Name="ThumbTranslate" X="0"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                </Border>
                <ContentPresenter Margin="12,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
            <ControlTemplate.Triggers>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="SwitchBg" Property="Background" Value="{StaticResource AccentColor}"/>
                    <Setter TargetName="SwitchBg" Property="BorderThickness" Value="0"/>
                </Trigger>
                <EventTrigger RoutedEvent="CheckBox.Checked">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate" Storyboard.TargetProperty="X" To="20" Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="CheckBox.Unchecked">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="ThumbTranslate" Storyboard.TargetProperty="X" To="0" Duration="0:0:0.2">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template" Value="{StaticResource ToggleSwitchTemplate}"/>
        </Style>

        <!-- Шаблон для парящих вкладок -->
        <ControlTemplate x:Key="TabItemTemplate" TargetType="TabItem">
            <Border Name="Border" Padding="25,12" Margin="0,0,10,0" Background="Transparent" CornerRadius="8">
                <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="#33ffffff"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="Border" Property="Background" Value="#1affffff"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#a1a1aa"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template" Value="{StaticResource TabItemTemplate}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- СТИЛИ ДЛЯ КРАСИВОГО COMBOBOX (ВЫПАДАЮЩИЙ СПИСОК) -->
        <ControlTemplate x:Key="ComboBoxToggleButton" TargetType="ToggleButton">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition Width="30" />
                </Grid.ColumnDefinitions>
                <Border x:Name="Border" Grid.ColumnSpan="2" CornerRadius="8" Background="#26ffffff" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" />
                <Border Grid.Column="0" CornerRadius="8,0,0,8" Margin="1" Background="Transparent" />
                <Path x:Name="Arrow" Grid.Column="1" Fill="White" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M0,0 L0,2 L4,6 L8,2 L8,0 L4,4 z" />
            </Grid>
            <ControlTemplate.Triggers>
                <Trigger Property="ToggleButton.IsMouseOver" Value="true">
                    <Setter TargetName="Border" Property="Background" Value="#33ffffff" />
                </Trigger>
                <Trigger Property="ToggleButton.IsChecked" Value="true">
                    <Setter TargetName="Border" Property="Background" Value="#40ffffff" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <ControlTemplate x:Key="ComboBoxTextBox" TargetType="TextBox">
            <Border x:Name="PART_ContentHost" Focusable="False" Background="{TemplateBinding Background}" />
        </ControlTemplate>

        <Style x:Key="GlassComboBox" TargetType="ComboBox">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="SnapsToDevicePixels" Value="true" />
            <Setter Property="OverridesDefaultStyle" Value="true" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="true" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton Name="ToggleButton" Template="{StaticResource ComboBoxToggleButton}" Grid.Column="2" Focusable="false"
                                          IsChecked="{Binding Path=IsDropDownOpen,Mode=TwoWay,RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press"/>
                            <ContentPresenter Name="ContentSite" IsHitTestVisible="False" Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                              Margin="15,0,30,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                            <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                <!-- Выпадающее меню -->
                                <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border x:Name="DropDownBorder" Background="#1f1f22" BorderThickness="1" BorderBrush="{StaticResource GlassBorder}" CornerRadius="8" Margin="0,5,0,0"/>
                                    <ScrollViewer Margin="4,9,4,4" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Grid>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="false">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="95" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стилизация элементов внутри ComboBox -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="SnapsToDevicePixels" Value="true" />
            <Setter Property="OverridesDefaultStyle" Value="true" />
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border Name="Border" Padding="10,8" Margin="0,2" SnapsToDevicePixels="true" CornerRadius="5" Background="Transparent">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="true">
                                <Setter TargetName="Border" Property="Background" Value="#3f3f46" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="true">
                                <Setter TargetName="Border" Property="Background" Value="{StaticResource AccentColor}" />
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- Фон окна со светящимися "пятнами" на заднем плане (создает глубину) -->
    <Grid>
        <!-- Темный фон -->
        <Rectangle Fill="#09090b"/>
        <!-- Фиолетовое свечение сверху слева -->
        <Rectangle Margin="-200,-200,0,0" Width="600" Height="600" HorizontalAlignment="Left" VerticalAlignment="Top" Opacity="0.15">
            <Rectangle.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#8b5cf6" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>
        <!-- Синее свечение снизу справа -->
        <Rectangle Margin="0,0,-200,-200" Width="500" Height="500" HorizontalAlignment="Right" VerticalAlignment="Bottom" Opacity="0.1">
            <Rectangle.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#3b82f6" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </RadialGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- Основной контент -->
        <Grid>
            <!-- Верхняя шапка (Стекло) -->
            <Border Height="70" VerticalAlignment="Top" Background="#80000000" BorderBrush="{StaticResource GlassBorder}" BorderThickness="0,0,0,1">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="25,0,0,0">
                    <TextBlock Text="🚀" FontSize="26" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <TextBlock Text="SupaModd Launcher" FontSize="24" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                    <Border Background="#26ffffff" CornerRadius="6" Padding="6,2" Margin="15,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="v1.0" FontSize="13" FontWeight="Bold" Foreground="{StaticResource AccentColor}"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Основной TabControl -->
            <TabControl Background="Transparent" BorderThickness="0" Margin="20,90,20,20">

                <!-- ВКЛАДКА 1: ОБХОД DPI -->
                <TabItem>
                    <TabItem.Header>
                        <TextBlock Text="Обход DPI" FontSize="16" FontWeight="SemiBold" Padding="10,2"/>
                    </TabItem.Header>
                    <Grid Margin="0,20,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Панель управления (Стеклянная карточка) -->
                        <Border Background="{StaticResource GlassBg}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" CornerRadius="12" Padding="25">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Переключатели -->
                                <StackPanel Grid.Column="0" Orientation="Vertical" VerticalAlignment="Center" Margin="0,0,40,0">
                                    <CheckBox x:Name="chkDiscord" Content="Разблокировать Discord" IsChecked="True" Style="{StaticResource ToggleSwitch}" Margin="0,0,0,20"/>
                                    <CheckBox x:Name="chkYouTube" Content="Разблокировать YouTube" IsChecked="True" Style="{StaticResource ToggleSwitch}"/>
                                </StackPanel>

                                <!-- Выбор стратегии -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Метод обхода (Стратегия):" Foreground="#a1a1aa" FontSize="14" Margin="0,0,0,8"/>

                                    <!-- Полностью стилизованный ComboBox -->
                                    <ComboBox x:Name="cmbStrategy" Height="40" FontSize="15" SelectedIndex="5" Style="{StaticResource GlassComboBox}">
                                        <ComboBoxItem Content="1. Flowseal (General)"/>
                                        <ComboBoxItem Content="2. Flowseal (ALT 1)"/>
                                        <ComboBoxItem Content="3. Flowseal (ALT 2)"/>
                                        <ComboBoxItem Content="4. Flowseal (ALT 3)"/>
                                        <ComboBoxItem Content="5. Flowseal (FAKE TLS AUTO ALT)"/>
                                        <ComboBoxItem Content="6. SupaModd Custom (Макс. Пробив)"/>
                                    </ComboBox>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <TextBlock Grid.Row="1" Text="Логи консоли:" Foreground="#a1a1aa" FontSize="14" Margin="5,20,0,8"/>

                        <!-- Окно логов консоли (Мягкий темный фон внутри стекла) -->
                        <Border Grid.Row="2" Background="#80000000" CornerRadius="10" BorderThickness="1" BorderBrush="#26ffffff">
                            <TextBox x:Name="txtLogs" Background="Transparent" Foreground="#a78bfa" 
                                     IsReadOnly="True" TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto" 
                                     FontFamily="Consolas" BorderThickness="0" Padding="15" FontSize="14"/>
                        </Border>

                        <!-- Нижние кнопки -->
                        <Grid Grid.Row="3" Margin="0,20,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Button Content="▶ Тест в окне" Width="140" Style="{StaticResource AccentButton}" Margin="0,0,15,0" Click="BtnStart_Click"/>
                                <Button Content="⏹ Остановить тест" Width="140" Style="{StaticResource GlassButton}" Click="BtnStop_Click"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="🛡 Установить Службу" Width="190" Style="{StaticResource GlassButton}" Margin="0,0,15,0" Click="BtnInstallService_Click"/>
                                <Button Content="Удалить Службу" Width="150" Style="{StaticResource DangerButton}" Click="BtnRemoveService_Click"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </TabItem>

                <!-- ВКЛАДКА 2: ДОП ФУНКЦИИ -->
                <TabItem>
                    <TabItem.Header>
                        <TextBlock Text="Инструменты" FontSize="16" FontWeight="SemiBold" Padding="10,2"/>
                    </TabItem.Header>
                    <Grid Margin="0,20,0,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,60,0,0">

                            <!-- Карточка 1 -->
                            <Border Background="{StaticResource GlassBg}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" CornerRadius="15" Width="240" Height="220" Margin="0,0,25,0" Padding="25">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="🌐" FontSize="45" HorizontalAlignment="Center" Margin="0,0,0,15">
                                        <TextBlock.Effect>
                                            <DropShadowEffect Color="White" BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
                                        </TextBlock.Effect>
                                    </TextBlock>
                                    <TextBlock Text="Пинг серверов" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock Text="Проверка доступности Discord и YouTube" TextWrapping="Wrap" TextAlignment="Center" Foreground="#a1a1aa" FontSize="13" Margin="0,0,0,20"/>
                                    <Button Content="Скоро" Style="{StaticResource GlassButton}" IsEnabled="False" Padding="10,8"/>
                                </StackPanel>
                            </Border>

                            <!-- Карточка 2 -->
                            <Border Background="{StaticResource GlassBg}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" CornerRadius="15" Width="240" Height="220" Margin="0,0,25,0" Padding="25">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="🔄" FontSize="45" HorizontalAlignment="Center" Margin="0,0,0,15">
                                        <TextBlock.Effect>
                                            <DropShadowEffect Color="White" BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
                                        </TextBlock.Effect>
                                    </TextBlock>
                                    <TextBlock Text="Обновить списки" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock Text="Скачать актуальные домены с GitHub" TextWrapping="Wrap" TextAlignment="Center" Foreground="#a1a1aa" FontSize="13" Margin="0,0,0,20"/>
                                    <Button Content="Скоро" Style="{StaticResource GlassButton}" IsEnabled="False" Padding="10,8"/>
                                </StackPanel>
                            </Border>

                            <!-- Карточка 3 -->
                            <Border Background="{StaticResource GlassBg}" BorderBrush="{StaticResource GlassBorder}" BorderThickness="1" CornerRadius="15" Width="240" Height="220" Padding="25">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="🧹" FontSize="45" HorizontalAlignment="Center" Margin="0,0,0,15">
                                        <TextBlock.Effect>
                                            <DropShadowEffect Color="White" BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
                                        </TextBlock.Effect>
                                    </TextBlock>
                                    <TextBlock Text="Сброс сети" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock Text="Очистка кэша DNS для решения проблем" TextWrapping="Wrap" TextAlignment="Center" Foreground="#a1a1aa" FontSize="13" Margin="0,0,0,20"/>
                                    <Button Content="Очистить" Style="{StaticResource GlassButton}" Padding="10,8" Click="BtnFlushDns_Click"/>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </Grid>
                </TabItem>

            </TabControl>
        </Grid>
    </Grid>
</Window>